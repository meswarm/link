# Link 全局环境配置
# ═══════════════════════════════════════
#
# 所有 API Key 集中存放于此，通过环境变量名与模型配置关联：
#   models/qwen-plus.yaml  → api_key: "${DASHSCOPE_API_KEY}"
#   models/gpt-4o.yaml     → api_key: "${OPENAI_API_KEY}"
#   models/deepseek-v3.yaml→ api_key: "${DEEPSEEK_API_KEY}"
#
# 只需填写你实际使用的模型对应的 Key，其余留空即可。

# ── Matrix 服务器 ──
MATRIX_HOMESERVER=http://192.168.3.5:6167

# ── API Keys（按需填写）──
# DASHSCOPE_API_KEY=sk-xxx
# OPENAI_API_KEY=sk-xxx
# DEEPSEEK_API_KEY=sk-xxx
# ZHIPU_API_KEY=xxx
# ANTHROPIC_API_KEY=sk-xxx

# ── R2 对象存储（可选，用于带外媒体存储）──
# 配置后在 Agent YAML 中设置 media_storage: "r2" 即可启用
# R2_ENDPOINT=https://xxx.r2.cloudflarestorage.com
# R2_ACCESS_KEY=your_access_key
# R2_SECRET_KEY=your_secret_key
# R2_BUCKET=link-media
# R2_PUBLIC_URL=https://media.example.com
